<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/settings" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/settings"
                android:layout_marginStart="10dp"
                android:textAlignment="center"
                android:textSize="25sp" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:orientation="vertical">


            <CheckBox
                android:id="@+id/sound"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/sound"
                android:textSize="15sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sound2"
                android:layout_marginStart="25dp"/>

            <CheckBox
                android:id="@+id/vibrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/vibrate"
                android:textSize="15sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vibrate2"
                android:layout_marginStart="25dp"/>
            <CheckBox
                android:id="@+id/preview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/preview"
                android:textSize="15sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preview2"
                android:layout_marginStart="25dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TYPING ASSISTANCE"
            android:textSize="15sp"
            android:textColor="@color/black"
            android:layout_marginTop="20dp"
            android:layout_marginStart="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <CheckBox
                android:id="@+id/autoCloseBrackets"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:text="@string/auto_close_brackets"
                android:textSize="15sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_close_brackets2"
                android:layout_marginStart="25dp"/>

            <CheckBox
                android:id="@+id/autoCloseQuotes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:text="@string/auto_close_quotes"
                android:textSize="15sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_close_quotes2"
                android:layout_marginStart="25dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/caps_lock_style_label"
            android:textSize="15sp"
            android:textColor="@color/black"
            android:layout_marginTop="20dp"
            android:layout_marginStart="20dp"/>

        <RadioGroup
            android:id="@+id/capsLockStyleGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:orientation="vertical">
            <RadioButton
                android:id="@+id/capsGboard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/caps_gboard"
                android:checked="true"/>
            <RadioButton
                android:id="@+id/capsLaptop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/caps_laptop"/>
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KEYBOARD COLOUR"
            android:textSize="15sp"
            android:textColor="@color/black"
            android:layout_marginTop="20dp"
            android:layout_marginStart="20dp"/>
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:scrollbars="none">
            <RadioGroup
                android:id="@+id/radioGroupColour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/backRadio"
                    android:layout_width="90dp"
                    android:text="DARK"
                    android:textAlignment="center"
                    android:textColor="@color/white"
                    android:layout_height="wrap_content"
                    android:background="@drawable/chooseblack"
                    android:layout_marginEnd="5dp"
                    android:checked="true"/>
                <RadioButton
                    android:id="@+id/whiteRadio"
                    android:layout_width="90dp"
                    android:text="GREY"
                    android:textAlignment="center"
                    android:layout_height="wrap_content"
                    android:background="@drawable/whitechoose"
                    android:layout_marginEnd="5dp"/>
                <RadioButton
                    android:id="@+id/blueRadio"
                    android:layout_width="90dp"
                    android:text="NAVY"
                    android:textAlignment="center"
                    android:textColor="@color/white"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bluechoose"
                    android:layout_marginEnd="5dp"/>
                <RadioButton
                    android:id="@+id/redRadio"
                    android:layout_width="90dp"
                    android:text="HACKER"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:layout_height="wrap_content"
                    android:background="@drawable/choosered"
                    android:layout_marginEnd="5dp"/>
                <RadioButton
                    android:id="@+id/greenRadio"
                    android:layout_width="90dp"
                    android:text="AMOLED"
                    android:textAlignment="center"
                    android:textColor="@color/white"
                    android:layout_height="wrap_content"
                    android:background="@drawable/greenchoose"/>
            </RadioGroup>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="KEYBOARD SIZE"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:layout_marginStart="20dp"/>

            <SeekBar
                android:id="@+id/seekBar"
                style="@style/Widget.AppCompat.SeekBar.Discrete"
                android:layout_width="match_parent"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="8dp"
                android:max="3"
                android:progress="1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XS"
                    android:textSize="11sp"
                    android:layout_marginStart="30dp"/>
                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S"
                    android:textSize="12sp"/>
                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="M"
                    android:textSize="14sp"/>
                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="L"
                    android:layout_marginEnd="30dp"
                    android:textSize="16sp"/>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KEYBOARD LAYOUT"
            android:textSize="15sp"
            android:textColor="@color/black"
            android:layout_marginTop="20dp"
            android:layout_marginStart="20dp"/>
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:scrollbars="none">
            <RadioGroup
                android:id="@+id/keylayouts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/querty"
                    android:layout_width="100dp"
                    android:text="QWERTY"
                    android:textAlignment="center"
                    android:layout_height="wrap_content"
                    android:background="@drawable/roundbtn"
                    android:layout_marginEnd="5dp"
                    android:checked="true"/>
                <RadioButton
                    android:id="@+id/dvorak"
                    android:layout_width="100dp"
                    android:text="DVORAK"
                    android:textAlignment="center"
                    android:layout_height="wrap_content"
                    android:background="@drawable/roundbtn"
                    android:layout_marginEnd="5dp" />
                <RadioButton
                    android:id="@+id/azerty"
                    android:layout_width="100dp"
                    android:text="AZERTY"
                    android:textAlignment="center"
                    android:layout_height="wrap_content"
                    android:background="@drawable/roundbtn"
                    android:layout_marginEnd="5dp" />
                <RadioButton
                    android:id="@+id/qwertz"
                    android:layout_width="100dp"
                    android:text="QWERTZ"
                    android:textAlignment="center"
                    android:layout_height="wrap_content"
                    android:background="@drawable/roundbtn"
                    android:layout_marginEnd="5dp"/>
                <RadioButton
                    android:id="@+id/colemak"
                    android:layout_width="100dp"
                    android:text="COLEMAK"
                    android:textAlignment="center"
                    android:layout_height="wrap_content"
                    android:background="@drawable/roundbtn"
                    android:layout_marginEnd="5dp"/>
                <RadioButton
                    android:id="@+id/colemakDh"
                    android:layout_width="110dp"
                    android:text="COLEMAK-DH"
                    android:textAlignment="center"
                    android:layout_height="wrap_content"
                    android:background="@drawable/roundbtn"/>
            </RadioGroup>
        </HorizontalScrollView>

        <!-- Placeholder so settings.java compiles in paid flavor (AdManager is a no-op) -->
        <View
            android:id="@+id/settings_banner_ad"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"/>

    </LinearLayout>

    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
